# Selko Environment Configuration
# Copy this file to .env, .env.test, or .env.production and fill in values

# =============================================================================
# Environment Configuration
# =============================================================================

# Environment: development, staging, or production
# This variable determines which .env file to load:
#   development -> .env (local Supabase via Docker)
#   staging     -> .env.test (cloud Supabase staging)
#   production  -> .env.production (cloud Supabase production)
ENVIRONMENT=development

# =============================================================================
# Supabase Configuration
# =============================================================================

# Project URL (local: http://localhost:54321, cloud: https://<ref>.supabase.co)
SUPABASE_URL=http://localhost:54321

# Publishable key (safe for client-side, supports key rotation)
# Find in: Dashboard > Settings > API > Publishable key
# Format: sb_publishable_XXXXXXX
SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>

# Service role key (server-side only, has admin access)
# Find in: Dashboard > Settings > API > Secret keys
# Format: sb_secret_XXXXXXX
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Direct PostgreSQL connection (for migrations and admin tasks)
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Project reference ID (for CLI operations)
SUPABASE_PROJECT_REF=<your-project-ref>

# Database password (for cloud projects)
SUPABASE_DB_PASSWORD=<your-db-password>

# JWT Secret for API authentication (Dashboard > Settings > API > JWT Settings)
SUPABASE_JWT_SECRET=<your-jwt-secret>

# =============================================================================
# Google OAuth Configuration
# =============================================================================

# OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com

# OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=<your-client-secret>

# Microsoft Graph / Outlook OAuth (Azure Entra app registration)
MICROSOFT_CLIENT_ID=<your-microsoft-app-id>
MICROSOFT_CLIENT_SECRET=<your-microsoft-client-secret>

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Active LLM provider: qwen, gemini, moonshot, zai, deepseek, minimax
LLM_PROVIDER=qwen

# Specific model ID (optional, uses provider default if not set)
# Examples: qwen3.5-flash, gemini-3-flash-preview, kimi-k2.5, glm-4.6v-flash
# LLM_MODEL=qwen3.5-flash

# --- Gemini (Google) ---
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=<your-gemini-api-key>

# --- Moonshot / Kimi (vision, OpenAI-compatible) ---
# MOONSHOT_API_KEY=<your-moonshot-api-key>

# --- Z.AI / Zhipu (vision + text, OpenAI-compatible) ---
# ZAI_API_KEY=<your-zai-api-key>

# --- DeepSeek (text-only, OpenAI-compatible) ---
# DEEPSEEK_API_KEY=<your-deepseek-api-key>

# --- Alibaba / Qwen (vision + text, OpenAI-compatible) ---
# ALIBABA_API_KEY=<your-alibaba-api-key>

# --- MiniMax (text-only, OpenAI-compatible) ---
# MINIMAX_API_KEY=<your-minimax-api-key>

# =============================================================================
# Test User Configuration (for CLI tools)
# =============================================================================

# Test user credentials for CLI authentication
# Create user via: uv run python -m cli.cli_user create --email <email> --password <password>
TEST_USER_EMAIL=test@selko.local
TEST_USER_PASSWORD=<your-test-password>

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins for CORS (comma-separated list)
# If not set, defaults to localhost development servers
# Examples:
#   Development: http://localhost:3000,http://localhost:5173
#   Staging: https://selko-web-staging.onrender.com
#   Production: https://selko-web.onrender.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Public API URL used as the default Google OAuth callback base (no trailing slash)
# Staging: https://selko.onrender.com
# Production: https://selko-production.onrender.com
API_PUBLIC_URL=http://localhost:8000

# Frontend URL for post-OAuth redirects (no trailing slash)
# Staging: https://selko-web-staging.onrender.com
# Production: https://selko-web.onrender.com
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Background Processing Configuration
# =============================================================================

# Enable background processing (workers + scheduler)
# Set to true to enable automatic email fetching and job processing
# Default: false (disabled)
ENABLE_BACKGROUND_PROCESSING=false
